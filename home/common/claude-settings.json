{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": ["mcp__svelte__*"]
  },
  "model": "opus",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "elements-of-style@superpowers-marketplace": true,
    "superpowers-lab@superpowers-marketplace": true,
    "lazyweb@lazyweb": true
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [".", "~/loam"],
      "denyWrite": ["/"],
      "denyRead": ["~/"],
      "allowRead": [".", "~/workspace", "~/loam", "~/remote"]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "svelte": {
      "args": ["-y", "@sveltejs/mcp"],
      "command": "npx"
    }
  },
  "plugins": {},
  "preferNativeInstaller": false
}
